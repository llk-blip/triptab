# Copy this file to .env — these defaults work as-is for local use.

# Local SQLite database file (created by `npx prisma migrate dev`).
DATABASE_URL="file:./dev.db"

# Optional. Rates come from open.er-api.com free endpoint (no key needed).
# For higher limits, get a free key at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=""
